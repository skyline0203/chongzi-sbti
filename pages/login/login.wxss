/* pages/login/login.wxss */
/* 
 * 登录页样式
 * 保持与首页、答题页一致的大字报纯黑风格
 */

/* 页面容器 */
.page {
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 顶部装饰条 — 和首页一样 */
.top-bar {
  width: 100%;
  background: #000000;
  padding: 12rpx 0;
  text-align: center;
}
.bar-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}

/* 登录卡片容器 */
.login-card {
  width: 80%;
  border: 4px solid #000000;
  background: #FFFFFF;
  padding: 60rpx 40rpx;
  margin-top: 100rpx;
  text-align: center;
}

/* 登录图标 */
.login-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

/* 登录标题 */
.login-title {
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
  color: #000000;
}

/* 登录描述 */
.login-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 30rpx;
  letter-spacing: 1rpx;
}

/* 分隔线 */
.login-divider {
  width: 60%;
  height: 3rpx;
  background: #000000;
  margin: 0 auto 40rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  background: #000000;
  color: #FFFFFF;
  border: 3px solid #000000;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 30rpx;
  border-radius: 0 !important;  /* 去掉微信按钮默认圆角 */
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  line-height: 1.5;
}
.login-btn::after {
  border: none;  /* 去掉微信按钮默认边框 */
}
.login-btn:active {
  background: #333333;
}
.login-btn-icon {
  font-size: 32rpx;
}
.login-btn-text {
  font-weight: 900;
}

/* 加载中按钮 */
.loading-btn {
  background: #666666;
  border-color: #666666;
  pointer-events: none;  /* 加载中时禁止点击 */
}

/* 提示文字 */
.login-tips {
  margin-top: 20rpx;
}
.tips-text {
  display: block;
  font-size: 20rpx;
  color: #999999;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

/* 管理员模式提示 */
.admin-hint {
  margin-top: 30rpx;
  border: 2px solid #CC0000;
  padding: 16rpx;
}
.admin-hint-text {
  font-size: 24rpx;
  color: #CC0000;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 返回按钮 */
.back-btn {
  margin-top: 60rpx;
  font-size: 26rpx;
  color: #999999;
  letter-spacing: 4rpx;
  padding: 20rpx;
}

/* 底部 */
.footer {
  margin-top: auto;
  padding: 40rpx;
}
.footer-text {
  font-size: 20rpx;
  color: #CCCCCC;
  letter-spacing: 4rpx;
}
