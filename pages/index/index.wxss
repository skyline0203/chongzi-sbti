/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
}

/* 顶部装饰条 */
.top-bar {
  width: 100%;
  background: #000000;
  padding: 12rpx 0;
  text-align: center;
}
.bar-text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}

/* 头像区域 */
.avatar-section {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}
.avatar-border {
  border: 4px solid #000000;
  width: 260rpx;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  position: relative;
}
.avatar-border::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border: 2px solid #000000;
}
.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.avatar-emoji {
  font-size: 100rpx;
}
.avatar-label {
  font-size: 32rpx;
  font-weight: 900;
  margin-top: 8rpx;
  letter-spacing: 12rpx;
}

/* 标题区域 */
.title-section {
  text-align: center;
  margin-bottom: 40rpx;
}
.title-line-1 {
  font-size: 60rpx;
  font-weight: 900;
  letter-spacing: 12rpx;
  color: #000000;
}
.title-divider {
  width: 80%;
  height: 4rpx;
  background: #000000;
  margin: 20rpx auto;
}
.title-line-2 {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 16rpx;
  color: #000000;
}
.title-sub {
  font-size: 24rpx;
  color: #000000;
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

/* 标签区域 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 60rpx;
  padding: 0 40rpx;
}
.tag {
  border: 2px solid #000000;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* 按钮区域 */
.btn-section {
  margin-bottom: 60rpx;
}
.start-btn {
  border: 4px solid #000000;
  background: #000000;
  padding: 30rpx 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}
.start-btn:active {
  background: #333333;
  transform: scale(0.98);
}
.btn-text {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}
.btn-arrow {
  color: #FFFFFF;
  font-size: 32rpx;
}

/* 底部信息 */
.footer {
  text-align: center;
  padding: 40rpx;
  margin-top: auto;
}
.footer-line {
  font-size: 24rpx;
  color: #000000;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}
.footer-credit {
  font-size: 20rpx;
  color: #999999;
  margin-top: 20rpx;
  letter-spacing: 4rpx;
}
