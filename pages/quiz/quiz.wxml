<!--pages/quiz/quiz.wxml-->
<!--
  ============================================================
  答题页界面 — 用户在这里完成 15 道选择题
  ============================================================
  
  页面结构（从上到下）：
  1. 进度条 — 显示当前做到第几题
  2. 题目区 — 显示当前题目的文字
  3. 选项区 — 4 个可点击的选项（A/B/C/D）
  4. 操作按钮 — 上一题 / 下一题
  
  关键语法：
  - wx:for="{{数组}}" = 循环渲染（类似 for 循环）
  - wx:key="index" = 循环时的唯一标识（性能优化）
  - class="{{条件 ? '样式A' : '样式B'}}" = 条件样式
  ============================================================
-->

<view class="page">
  <!-- 
    进度条 
    progress 变量 = 0-100 的数字
    style="width: {{progress}}%" = 动态设置宽度
  -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
  <view class="progress-text">{{currentIndex + 1}} / {{total}}</view>

  <!-- 
    题目区域 
    CSS 中用 ::before 伪元素在左上角显示 "Q" 标签
  -->
  <view class="question-section">
    <view class="question-number">第 {{currentIndex + 1}} 题</view>
    <view class="question-text">{{currentQuestion.text}}</view>
  </view>

  <!-- 
    选项区域 
    wx:for 循环渲染 4 个选项
    selectedOption === index ? 'option-selected' : '' = 选中高亮
    data-index = 把下标存到元素上，点击时可以从 e 中获取
  -->
  <view class="options-section">
    <view
      class="option-item {{selectedOption === index ? 'option-selected' : ''}}"
      wx:for="{{currentQuestion.options}}"
      wx:key="index"
      bindtap="selectOption"
      data-index="{{index}}"
    >
      <view class="option-letter">{{optionLetters[index]}}</view>
      <view class="option-text">{{item.text}}</view>
    </view>
  </view>

  <!-- 
    操作按钮 
    btn-disabled = 第一题时禁用"上一题"按钮
    currentIndex === total - 1 = 最后一题时显示"查看结果"
  -->
  <view class="action-section">
    <view class="btn-prev {{currentIndex === 0 ? 'btn-disabled' : ''}}" bindtap="prevQuestion">
      ← 上一题
    </view>
    <view class="btn-next" bindtap="nextQuestion">
      {{currentIndex === total - 1 ? '查看结果 →' : '下一题 →'}}
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="quiz-footer">
    <view class="footer-bar"></view>
    <text class="footer-text">翀子小工具 · 艾斯BTI</text>
  </view>
</view>
