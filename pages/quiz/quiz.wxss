/* pages/quiz/quiz.wxss */
.page {
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  padding: 0 32rpx;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #EEEEEE;
  border: 2px solid #000000;
  margin-top: 20rpx;
  position: relative;
}
.progress-fill {
  height: 100%;
  background: #000000;
  transition: width 0.3s ease;
}
.progress-text {
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  margin: 12rpx 0;
  letter-spacing: 4rpx;
}

/* 题目区域 */
.question-section {
  border: 3px solid #000000;
  padding: 40rpx;
  margin: 20rpx 0 30rpx;
  background: #FFFFFF;
  position: relative;
}
.question-section::before {
  content: 'Q';
  position: absolute;
  top: -20rpx;
  left: 20rpx;
  background: #000000;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 900;
  padding: 4rpx 16rpx;
  letter-spacing: 2rpx;
}
.question-number {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}
.question-text {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.6;
  color: #000000;
  letter-spacing: 2rpx;
}

/* 选项区域 */
.options-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}
.option-item {
  border: 2px solid #000000;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #FFFFFF;
  transition: all 0.15s ease;
}
.option-item:active {
  background: #F5F5F5;
}
.option-selected {
  background: #000000 !important;
  color: #FFFFFF;
}
.option-selected .option-letter {
  color: #000000;
  background: #FFFFFF;
  border-color: #FFFFFF;
}
.option-selected .option-text {
  color: #FFFFFF;
}
.option-letter {
  min-width: 52rpx;
  height: 52rpx;
  border: 2px solid #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
}
.option-text {
  font-size: 28rpx;
  line-height: 1.6;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}
.btn-prev,
.btn-next {
  flex: 1;
  border: 2px solid #000000;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}
.btn-prev {
  background: #FFFFFF;
  color: #000000;
}
.btn-next {
  background: #000000;
  color: #FFFFFF;
}
.btn-prev:active,
.btn-next:active {
  opacity: 0.8;
}
.btn-disabled {
  opacity: 0.3;
  pointer-events: none;
}

/* 底部 */
.quiz-footer {
  margin-top: auto;
  text-align: center;
  padding: 30rpx 0;
}
.footer-bar {
  width: 60rpx;
  height: 4rpx;
  background: #000000;
  margin: 0 auto 12rpx;
}
.footer-text {
  font-size: 20rpx;
  color: #999999;
  letter-spacing: 4rpx;
}
